@echo off
rem Register the @SHELL_APP@ Explorer context-menu (per-user, no elevation needed).
rem Generated by CMake from common/shell/register.bat.in — do not edit by hand.
rem The regsvr32 below matches the DLL bitness on purpose: a 32-bit handler must be
rem loaded by the SysWOW64 regsvr32 so its HKCU\Software\Classes writes land in the
rem 32-bit registry view that 32-bit Explorer hosts read.
@SHELL_REGSVR@ /s "%~dp0@SHELL_DLL@"
if errorlevel 1 (
  echo Failed to register @SHELL_DLL@
) else (
  echo @SHELL_APP@ shell menu registered for the current user.
  echo Restart Explorer or sign out/in if the menu does not appear.
)
pause
